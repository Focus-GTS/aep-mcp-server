{
  "name": "@focusgts/aep-mcp-server",
  "version": "0.3.1",
  "description": "Full-featured open-source MCP server for Adobe Experience Platform — 34 tools across 10 categories: schemas, datasets, identities, profiles, segments, sources, destinations, query service, privacy service, and datastreams",
  "type": "module",
  "bin": {
    "aep-mcp": "dist/server.js"
  },
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/server.js",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:live": "tsx tests/integration/live-test.ts",
    "tools": "tsx scripts/list-tools.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "mcp",
    "adobe",
    "experience-platform",
    "aep",
    "rtcdp",
    "xdm",
    "segmentation"
  ],
  "author": "Focus GTS <dfox@focusgts.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Focus-GTS/aep-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/Focus-GTS/aep-mcp-server/issues"
  },
  "homepage": "https://github.com/Focus-GTS/aep-mcp-server#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "pino": "^9.6.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=20.18.0"
  },
  "files": [
    "dist/",
    ".env.example",
    "NOTICE"
  ]
}
